---
import { Content, frontmatter } from "../content/links.md";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <div>
      <span>{frontmatter.title}</span>
      <Content />
    </div>
  </body>
</html>

<style>
  body {
    background-color: white;
    color: black;
  }

  @media (prefers-color-scheme: dark) {
    body {
      background-color: #1a1a1a;
      color: white;
    }
  }
